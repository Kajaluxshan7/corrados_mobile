{
  "expo": {
    "name": "Corrado's",
    "slug": "corrados-restaurant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo-white-on-blue.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#243A7D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.corrados.restaurant",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo-white-on-blue.png",
        "backgroundColor": "#243A7D"
      },
      "package": "com.corrados.restaurant",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "6d18ed21-2ceb-4e5e-bd8d-a13a8daeca60"
      }
    },
    "owner": "subathran"
  }
}
